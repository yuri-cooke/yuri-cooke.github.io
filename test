<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dark/Light Mode Toggle</title>
    <link id="stylesheet" rel="stylesheet" href="light.css">
</head>
<body>
    <!-- Your HTML content -->
    <nav class="navbar">
        <button id="mode-toggle">Toggle Dark/Light Mode</button>
    </nav>

    <script src="script.js"></script>
</body>
</html>

// Function to toggle between light and dark mode
function toggleMode() {
    const stylesheet = document.getElementById('stylesheet');

    if (stylesheet.getAttribute('href') === 'light.css') {
        stylesheet.setAttribute('href', 'dark.css');
    } else {
        stylesheet.setAttribute('href', 'light.css');
    }
}

// Event listener for the mode toggle button
document.getElementById('mode-toggle').addEventListener('click', toggleMode);


